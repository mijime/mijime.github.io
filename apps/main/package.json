{
  "name": "@mijime/main",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node --experimental-wasm-modules ../../packages/blog/scripts/generate-parquet.mjs && astro build",
    "preview": "astro preview",
    "check": "pnpm run check:format && pnpm run check:oxlint && pnpm run check:astro",
    "check:format": "oxfmt --check src",
    "check:oxlint": "oxlint --format=github --fix",
    "check:astro": "astro check",
    "format": "pnpm run format:oxfmt",
    "format:oxfmt": "oxfmt src"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@mijime/blog": "workspace:*",
    "@mijime/madories": "workspace:*",
    "@mijime/mintodo": "workspace:*",
    "@mijime/saiflow": "workspace:*",
    "@mijime/theme": "workspace:*",
    "@tailwindcss/vite": "4.1.8",
    "astro": "^6.4.4",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
