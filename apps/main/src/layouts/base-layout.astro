---
import "../styles/global.css";
import { DarkModeToggle } from "@mijime/theme/DarkModeToggle";

interface Props {
  title?: string;
}
const { title = "mijime" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-logo">
          <span class="site-logo-text">mijime</span>
        </a>
        <nav class="site-nav">
          <DarkModeToggle client:only="react" />
        </nav>
      </div>
    </header>
    <slot />
  </body>
</html>
