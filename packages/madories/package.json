    "@types/uuid": "^11.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260429.1",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.62.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  },
