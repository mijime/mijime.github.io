---
export const prerender = true;
import BlogLayout from "../../../../../layouts/blog-layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { PAGE_SIZE } from "@mijime/blog";

export async function getStaticPaths() {
  const entries: CollectionEntry<"blog">[] = await getCollection("blog");
  const filtered = entries.filter((p) => !p.data.IsDraft);
  const allPosts = filtered
    .filter((p) => p.id.split("/").length === 3)
    .map((p) => {
      const [category, ym, slugMd] = p.id.split("/");
      return { ...p.data, category, ym, slug: slugMd.replace(/\.md$/, "") };
    })
    .toSorted((a, b) => {
      const da = a.CreatedAt ?? `${a.ym}-01`;
      const db = b.CreatedAt ?? `${b.ym}-01`;
      return db.localeCompare(da);
    });

  const tagMap = new Map<string, typeof allPosts>();
  for (const p of allPosts) {
    for (const t of p.Tags ?? []) {
      if (!tagMap.has(t)) tagMap.set(t, []);
      tagMap.get(t)!.push(p);
    }
  }

  const paths: {
    params: { tag: string; page: string };
    props: { tagPosts: typeof allPosts; pageCount: number };
  }[] = [];
  for (const [tag, tagPosts] of tagMap) {
    const pageCount = Math.max(1, Math.ceil(tagPosts.length / PAGE_SIZE));
    for (let i = 1; i <= pageCount; i++) {
      paths.push({
        params: { tag, page: String(i) },
        props: { tagPosts, pageCount },
      });
    }
  }
  return paths;
}

const { tag } = Astro.params;
const { tagPosts, pageCount } = Astro.props;
const page = Number(Astro.params.page);
const posts = tagPosts.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
---

<BlogLayout title={`tag: ${tag} page ${page}`}>
  <h1 class="post-tag">{tag}</h1>
  <ul class="post-list">
    {
      posts.map((p) => (
        <li class="post-list-item">
          <span class="post-date">{(p.CreatedAt ?? p.ym).slice(0, 10)}</span>
          <div>
            <a href={`/blog/${p.category}/${p.ym}/${p.slug}`}>{p.Title}</a>
            {p.Tags && p.Tags.length > 0 && (
              <span>
                {p.Tags.map((t: string) => (
                  <a href={`/blog/tag/${t}`} class="post-tag">
                    {t}
                  </a>
                ))}
              </span>
            )}
          </div>
        </li>
      ))
    }
  </ul>
  <nav class="pagination">
    {
      page > 1 && (
        <a
          href={
            page - 1 === 1
              ? `/blog/tag/${tag}`
              : `/blog/tag/${tag}/pages/${page - 1}`
          }
        >
          ← prev
        </a>
      )
    }
    <span>{page} / {pageCount}</span>
    {
      page < pageCount && (
        <a href={`/blog/tag/${tag}/pages/${page + 1}`}>next →</a>
      )
    }
  </nav>
</BlogLayout>
