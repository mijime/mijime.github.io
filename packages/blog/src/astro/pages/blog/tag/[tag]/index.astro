---
export const prerender = true;
import BlogLayout from "../../../../layouts/BlogLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { PAGE_SIZE } from "@mijime/blog";

export async function getStaticPaths() {
  const entries: CollectionEntry<"blog">[] = await getCollection("blog");
  const filtered = entries.filter((p) => !p.data.Draft);
  const allPosts = filtered
    .filter((p) => p.id.split("/").length === 3)
    .map((p) => {
      const [category, ym, slugMd] = p.id.split("/");
      return { ...p.data, category, ym, slug: slugMd.replace(/\.md$/, "") };
    })
    .toSorted((a, b) => {
      const da = a.Date ?? `${a.ym}-01`;
      const db = b.Date ?? `${b.ym}-01`;
      return db.localeCompare(da);
    });

  const tagMap = new Map<string, typeof allPosts>();
  for (const p of allPosts) {
    for (const t of p.Tags ?? []) {
      if (!tagMap.has(t)) tagMap.set(t, []);
      tagMap.get(t)!.push(p);
    }
  }

  return [...tagMap.entries()].map(([tag, tagPosts]) => ({
    params: { tag },
    props: {
      tagPosts,
      pageCount: Math.max(1, Math.ceil(tagPosts.length / PAGE_SIZE)),
    },
  }));
}

const { tag } = Astro.params;
const { tagPosts, pageCount } = Astro.props;
const page = 1;
const posts = tagPosts.slice(0, PAGE_SIZE);
---

<BlogLayout title={`tag: ${tag}`}>
  <h1 class="post-tag">{tag}</h1>
  <ul class="post-list">
    {
      posts.map((p) => (
        <li class="post-list-item">
          <span class="post-date">{p.Date ?? p.ym}</span>
          <div>
            <a href={`/blog/${p.category}/${p.ym}/${p.slug}`}>{p.Title}</a>
            {p.Tags && p.Tags.length > 0 && (
              <span>
                {p.Tags.map((t: string) => (
                  <a href={`/blog/tag/${t}`} class="post-tag">
                    {t}
                  </a>
                ))}
              </span>
            )}
          </div>
        </li>
      ))
    }
  </ul>
  <nav class="pagination">
    <span>{page} / {pageCount}</span>
    {
      page < pageCount && (
        <a href={`/blog/tag/${tag}/pages/${page + 1}`}>next →</a>
      )
    }
  </nav>
</BlogLayout>
