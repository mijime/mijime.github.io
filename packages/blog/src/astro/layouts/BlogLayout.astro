---
import "@mijime/blog/index.css";
import { BlogHeaderSearch } from "../components/BlogHeaderSearch";
import { DarkModeToggle } from "@mijime/theme/DarkModeToggle";

interface Props {
  title?: string;
}
const { title = "mijime" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="blog-root">
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="site-logo">
            <span class="site-logo-text">mijime</span>
          </a>
          <nav class="site-nav">
            <BlogHeaderSearch client:only="react" />
            <DarkModeToggle client:only="react" />
          </nav>
        </div>
      </header>
      <main class="blog-main">
        <slot />
      </main>
      <footer class="blog-footer">
        <span>© mijime</span>
      </footer>
    </div>
  </body>
</html>
