{
  "name": "@mijime/blog-contents",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "pnpm run check:format && pnpm run check:textlint",
    "check:format": "oxfmt --check",
    "check:textlint": "textlint 'contents/**/*.md'",
    "format": "pnpm run format:oxfmt && pnpm run format:tags",
    "format:oxfmt": "oxfmt",
    "format:tags": "tsx scripts/normalize-tags.ts 'contents/**/*.md' 'contents/**/*.mdx'"
  },
  "dependencies": {
    "lindera-js": "^0.1.4"
  },
  "devDependencies": {
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.7.0",
    "oxfmt": "^0.47.0",
    "textlint": "^15.7.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-japanese": "^10.0.4",
    "tsx": "^4.22.4"
  }
}
